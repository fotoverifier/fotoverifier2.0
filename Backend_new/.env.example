# Copy to ".env" and fill in real values (never commit ".env").

# Required — Redis for FastAPI and Celery (see main.py, tasks.py, celery_config.py)
REDIS_URL=redis://127.0.0.1:6379/0

# CORS — allowed browser origin for the Next.js app (see main.py)
FRONTEND_URL=http://localhost:9002

# Cloudinary (algorithms/utility.py)
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# OpenAI (algorithms/ai_validation.py)
OPENAI_API_KEY=

# SerpAPI (algorithms/exif.py)
SERPAPI_SECRET_KEY=
