# Copy to ".env" and/or ".env.local" (Next.js loads both; ".env.local" overrides).
# docker-compose uses "Frontend/.env" — keep names aligned for containers.

# Public — exposed to the browser (also wired in next.config.mjs)
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:9001

# Server-only — used by src/app/api/proxy/[...path]/route.ts to reach FastAPI
BACKEND_URL=http://127.0.0.1:9001

# Supabase — used by src/app/api/rating/route.ts
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
